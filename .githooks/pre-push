#!/usr/bin/env bash
# Pre-push hook: refuse to push if formatting, lint, or tests fail.
# Mirrors the CI in .github/workflows/{lint,test}.yml so failures show up
# locally instead of as red checks on a PR.
#
# Enable with: git config core.hooksPath .githooks
# Bypass once: git push --no-verify

set -e

echo "→ ruff format --check"
uv run ruff format --check

echo "→ ruff check"
uv run ruff check

echo "→ pytest"
uv run pytest

echo "✓ pre-push checks passed"
